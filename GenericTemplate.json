        "name": "ALLOW_CROSS_TENANT_REQUESTS",
        "value": "{ALLOW_CROSS_TENANT_REQUESTS}",
        "description": "Allows cross tenant interactions",
        "type": "CONFIG",
        "essential": false
      },
      {
        "name": "ENV",
        "value": "{ENV}",
        "description": "Environment",
        "type": "CONFIG",
        "essential": false
      },
      {
        "name": "JAVA_OPTS",
        "value": "{JAVA_OPTS}",
        "description": "Java options",
        "type": "CONFIG",
        "essential": false
      },
      {
        "name": "JAVA_PROFILER_OPTS",
        "value": "{JAVA_PROFILER_OPTS}",
        "description": "Java profiler options",
        "type": "CONFIG",
        "essential": false
      },
      {
        "name": "KAFKA_HOST",
        "value": "{KAFKA_HOST}",
        "description": "Kafka host",
        "type": "KAFKA",
        "essential": true
      },
      {
        "name": "KAFKA_PORT",
        "value": "{KAFKA_PORT}",
        "description": "Kafka port",
        "type": "KAFKA",
        "essential": true
      },
      {
        "name": "KC_ADMIN_CLIENT_ID",
        "value": "{KC_ADMIN_CLIENT_ID}",
        "description": "Master realm specific client id for authenticating requests to manager components.",
        "type": "KC",
        "essential": false
      },
      {
        "name": "KC_AUTHORIZATION_CACHE_MAX_SIZE",
        "value": "5000",
        "description": "Maximum amount of entries for keycloak authorization cache.",
        "type": "CACHE",
        "essential": false
      },
      {
        "name": "KC_LOGIN_CLIENT_SUFFIX",
        "value": "-application",
        "description": "Suffix of a Keycloak client who owns the authorization resources. It is used as audience for keycloak when evaluating permissions.",
        "type": "KC",
        "essential": false
      },
      {
        "name": "KC_SERVICE_CLIENT_ID",
        "value": "{KC_SERVICE_CLIENT_ID}",
        "description": "Tenant specific client id for authenticating egress requests.",
        "type": "KC",
        "essential": false
      },
      {
        "name": "KC_URI_VALIDATION_ENABLED",
        "value": "false",
        "description": "Defines if JsonWebTokenParser compares URI from token with KC_URL value.",
        "type": "KC",
        "essential": false
      },
      {
        "name": "KC_URL",
        "value": "{KC_URL}",
        "description": "Keycloak URL.",
        "type": "KC",
        "essential": false
      },
      {
        "name": "MOD_USERS_KEYCLOAK_URL",
        "value": "{MOD_USERS_KEYCLOAK_URL}",
        "description": "Mod-users-keycloak module url.",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "MODULE_NAME",
        "value": "{MODULE_NAME}",
        "description": "Underlying module name. If MODULE_ID is not specified, required",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "MODULE_URL",
        "value": "{MODULE_URL}",
        "description": "Underlying module URL.",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "MODULE_VERSION",
        "value": "{MODULE_VERSION}",
        "description": "Underlying module version. If MODULE_ID is not specified, required",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "QUARKUS_HTTP_LIMITS_MAX_BODY_SIZE",
        "value": "200M",
        "description": "",
