{
  "description": "{module} configuration template",
  "moduleDefaults": {
    "resources": [
      {
        "name": "cpu",
        "value": "{cpu}",
        "description": "CPU request/limit for container"
      },
      {
        "name": "memory",
        "value": "{memory}",
        "description": "Memory hard limit for container"
      },
      {
        "name": "memoryReservation",
        "value": "{memoryReservation}",
        "description": "Memory reservation for container"
      }
    ],
    "java": [
      {
        "name": "xmx",
        "value": "{xmx}",
        "description": "Maximum Java heap size"
      },
      {
        "name": "xms",
        "value": "{xms}",
        "description": "Initial Java heap size"
      },
      {
        "name": "MaxMetaspaceSize",
        "value": "{MaxMetaspaceSize}",
        "description": "Maximum Java metaspace size"
      },
      {
        "name": "MetaspaceSize",
        "value": "{MetaspaceSize}",
        "description": "Initial Java metaspace size"
      }
    ],
    "deployment": {
      "isHaSupported": true,
      "replicasRecommendedCount": 2,
      "description": "Deployment configuration for the backend module. Adjust replicas based on expected load and HA requirements. Set to false if only single instance is supported or required."
    },
    "kong": {
      "timeouts": {
        "connect": "60s",
        "send": "60s",
        "read": "60s"
      },
      "description": "Custom Kong proxy timeouts. Use this only if different from default Kong configuration"
    },
    "EnvVars": [
      {
        "name": "DB_DATABASE",
        "value": "{DB_DATABASE}",
        "description": "Database name",
        "type": "DB",
        "essential": true
      },
      {
        "name": "DB_EXPLAIN_QUERY_THRESHOLD",
        "value": "{DB_EXPLAIN_QUERY_THRESHOLD}",
        "description": "Threshold for explaining slow queries in milliseconds",
        "type": "DB",
        "essential": false
      },
      {
        "name": "DB_HOST",
        "value": "{DB_HOST}",
        "description": "Database host",
        "type": "DB",
        "essential": true
      },
      {
        "name": "DB_MAXPOOLSIZE",
        "value": "{DB_MAXPOOLSIZE}",
        "description": "Maximum database connection pool size",
        "type": "DB",
        "essential": false
      },
      {
        "name": "DB_PASSWORD",
        "value": "{DB_PASSWORD}",
        "description": "Database password",
        "type": "DB",
        "essential": true
      },
      {
        "name": "DB_PORT",
        "value": "{DB_PORT}",
        "description": "Database port",
        "type": "DB",
        "essential": true
      },
      {
        "name": "DB_USERNAME",
        "value": "{DB_USERNAME}",
        "description": "Database username",
        "type": "DB",
        "essential": true
      },

      {
        "name": "ENV",
        "value": "{ENV}",
        "description": "Environment",
        "type": "CONFIG",
        "essential": false
      },
      {
        "name": "JAVA_ARGS",
        "value": "{JAVA_ARGS}",
        "description": "Java arguments",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "JAVA_OPTS",
        "value": "{JAVA_OPTS}",
        "description": "Java options",
        "type": "CONFIG",
        "essential": true
      },
      {
        "name": "LOG4J_CONFIGURATION_FILE",
        "value": "{LOG4J_CONFIGURATION_FILE}",
        "description": "Log4j configuration file",
        "type": "CONFIG",
        "essential": false
      },

      {
        "name": "KAFKA_HOST",
        "value": "{KAFKA_HOST}",
        "description": "Kafka host",
        "type": "KAFKA",
        "essential": true
      },
      {
        "name": "KAFKA_PORT",
        "value": "{KAFKA_PORT}",
        "description": "Kafka port",
        "type": "KAFKA",
        "essential": true
      },

      {
        "name": "S3_ACCESS_KEY_ID",
        "value": "{S3_ACCESS_KEY_ID}",
        "description": "S3 access key",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_BUCKET",
        "value": "{S3_BUCKET}",
        "description": "S3 bucket",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_IS_AWS",
        "value": "{S3_IS_AWS}",
        "description": "Specify if AWS S3 is used as files storage",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_REGION",
        "value": "{S3_REGION}",
        "description": "S3 region",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_SECRET_ACCESS_KEY",
        "value": "{S3_SECRET_ACCESS_KEY}",
        "description": "S3 secret key",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_SUB_PATH",
        "value": "{S3_SUB_PATH}",
        "description": "S3 subpath for file storage",
        "type": "S3",
        "essential": true
      },
      {
        "name": "S3_URL",
        "value": "{S3_URL}",
        "description": "S3 url",
        "type": "S3",
        "essential": true
      }
    ]
  },

  "sidecarDefaults": {
    "resources": [
      {
        "name": "cpu",
        "value": "{cpu}",
        "description": "CPU request/limit for container"
      },
      {
        "name": "memory",
        "value": "{memory}",
        "description": "Memory hard limit for container"
      },
      {
        "name": "memoryReservation",
        "value": "{memoryReservation}",
        "description": "Memory reservation for container"
      }
    ],
    "java": [
      {
        "name": "xms",
        "value": "{xms}",
        "description": "Initial Java heap size"
      },
      {
        "name": "xmx",
        "value": "{xmx}",
        "description": "Maximum Java heap size"
      },
      {
        "name": "MaxMetaspaceSize",
        "value": "{MaxMetaspaceSize}",
        "description": "Maximum Java metaspace size"
      }
